<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>台股計算機</title>
</head>

<body>

<h2>台股損益計算機</h2>

<!-- 類型 -->
<label>類型：</label>
<select id="type">
  <option value="stock">股票</option>
  <option value="daytrade">當沖</option>
  <option value="etf">ETF</option>
</select>

<br><br>

<!-- 買入 -->
買入價格：<input type="number" id="buy" step="0.01"><br><br>

<!-- 賣出 -->
賣出價格：<input type="number" id="sell" step="0.01"><br><br>

<!-- 單位 -->
<label>單位：</label>
<select id="unit">
  <option value="lot">1張 (1000股)</option>
  <option value="share">1股</option>
</select>

<br><br>

<button onclick="calc()">計算</button>

<hr>

<h3>結果</h3>
<div id="result"></div>

<script>
function calc() {
  const type = document.getElementById("type").value;
  const buy = parseFloat(document.getElementById("buy").value);
  const sell = parseFloat(document.getElementById("sell").value);
  const unit = document.getElementById("unit").value;

  if (!buy || !sell) {
    alert("請輸入價格");
    return;
  }

  const qty = (unit === "lot") ? 1000 : 1;

  const buyCost = buy * qty;
  const sellValue = sell * qty;

  // 手續費 0.1425%（最低1元）
  let buyFee = Math.max(buyCost * 0.001425, 1);
  let sellFee = Math.max(sellValue * 0.001425, 1);

  // 證交稅
  let taxRate = 0;

  if (type === "stock") taxRate = 0.003;
  if (type === "etf") taxRate = 0.001;
  if (type === "daytrade") taxRate = 0.0015; // 當沖簡化

  let tax = sellValue * taxRate;

  const profit = sellValue - buyCost - buyFee - sellFee - tax;

  document.getElementById("result").innerHTML = `
    買入成本：${buyCost.toFixed(2)}<br>
    賣出金額：${sellValue.toFixed(2)}<br>
    買入手續費：${buyFee.toFixed(2)}<br>
    賣出手續費：${sellFee.toFixed(2)}<br>
    證交稅：${tax.toFixed(2)}<br>
    <h3>損益：${profit.toFixed(2)}</h3>
  `;
}
</script>

</body>
</html>
